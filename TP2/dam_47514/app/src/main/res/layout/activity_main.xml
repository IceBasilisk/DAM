<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageWeather"
            android:layout_width="106dp"
            android:layout_height="103dp"
            android:layout_marginStart="193dp"
            android:layout_marginTop="37dp"
            android:layout_marginEnd="194dp"
            android:layout_marginBottom="671dp"
            android:contentDescription="@string/imageDescription"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.597"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.262"
            app:srcCompat="@drawable/clear_day" />

        <Button
            android:id="@+id/buttonUpdate"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="154dp"
            android:layout_marginTop="200dp"
            android:layout_marginEnd="151dp"
            android:text="@string/label_button"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.873" />

        <TextView
            android:id="@+id/textViewLatitude"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginStart="70dp"
            android:layout_marginTop="160dp"
            android:text="@string/label_latitude"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/editTextLatitude"
            android:layout_width="178dp"
            android:layout_height="48dp"
            android:layout_marginStart="80dp"
            android:layout_marginEnd="28dp"
            android:ems="10"
            android:inputType="numberDecimal|numberSigned"
            android:text="@string/value_latitude"
            app:layout_constraintBottom_toBottomOf="@+id/textViewLatitude"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textViewLatitude"
            app:layout_constraintTop_toTopOf="@+id/textViewLatitude"
            app:layout_constraintVertical_bias="0.476"
            tools:ignore="LabelFor" />

        <TextView
            android:id="@+id/textViewLongitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/label_longitude"
            app:layout_constraintEnd_toEndOf="@+id/textViewLatitude"
            app:layout_constraintStart_toStartOf="@+id/textViewLatitude"
            app:layout_constraintTop_toBottomOf="@+id/textViewLatitude" />

        <EditText
            android:id="@+id/editTextLongitude"
            android:layout_width="178dp"
            android:layout_height="48dp"
            android:ems="10"
            android:inputType="numberDecimal|numberSigned"
            android:text="@string/value_longitude"
            app:layout_constraintBottom_toBottomOf="@+id/textViewLongitude"
            app:layout_constraintEnd_toEndOf="@+id/editTextLatitude"
            app:layout_constraintStart_toStartOf="@+id/editTextLatitude"
            app:layout_constraintTop_toTopOf="@+id/textViewLongitude"
            tools:ignore="LabelFor" />

        <TextView
            android:id="@+id/textViewSeaLevelLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/label_sea_level_pressure"
            app:layout_constraintEnd_toEndOf="@+id/textViewLongitude"
            app:layout_constraintStart_toStartOf="@+id/textViewLongitude"
            app:layout_constraintTop_toBottomOf="@+id/textViewLongitude" />

        <TextView
            android:id="@+id/textViewSeaLevelValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/value_sea_level_pressure"
            app:layout_constraintBottom_toBottomOf="@+id/textViewSeaLevelLabel"
            app:layout_constraintEnd_toEndOf="@+id/editTextLongitude"
            app:layout_constraintStart_toStartOf="@+id/editTextLongitude"
            app:layout_constraintTop_toTopOf="@+id/textViewSeaLevelLabel" />

        <TextView
            android:id="@+id/textViewWindDirectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/label_wind_direction"
            app:layout_constraintEnd_toEndOf="@+id/textViewSeaLevelLabel"
            app:layout_constraintStart_toStartOf="@+id/textViewSeaLevelLabel"
            app:layout_constraintTop_toBottomOf="@+id/textViewSeaLevelLabel" />

        <TextView
            android:id="@+id/textViewWindDirectionValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/value_wind_direction"
            app:layout_constraintBottom_toBottomOf="@+id/textViewWindDirectionLabel"
            app:layout_constraintEnd_toEndOf="@+id/textViewSeaLevelValue"
            app:layout_constraintStart_toStartOf="@+id/textViewSeaLevelValue"
            app:layout_constraintTop_toTopOf="@+id/textViewWindDirectionLabel" />

        <TextView
            android:id="@+id/textViewWindSpeedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/label_wind_speed"
            app:layout_constraintEnd_toEndOf="@+id/textViewWindDirectionLabel"
            app:layout_constraintStart_toStartOf="@+id/textViewWindDirectionLabel"
            app:layout_constraintTop_toBottomOf="@+id/textViewWindDirectionLabel" />

        <TextView
            android:id="@+id/textViewWindSpeedValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/value_wind_speed"
            app:layout_constraintBottom_toBottomOf="@+id/textViewWindSpeedLabel"
            app:layout_constraintEnd_toEndOf="@+id/textViewWindDirectionValue"
            app:layout_constraintStart_toStartOf="@+id/textViewWindDirectionValue"
            app:layout_constraintTop_toTopOf="@+id/textViewWindSpeedLabel" />

        <TextView
            android:id="@+id/textViewTemperatureLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/label_temperature"
            app:layout_constraintEnd_toEndOf="@+id/textViewWindSpeedLabel"
            app:layout_constraintStart_toStartOf="@+id/textViewWindSpeedLabel"
            app:layout_constraintTop_toBottomOf="@+id/textViewWindSpeedLabel" />

        <TextView
            android:id="@+id/textViewTemperatureValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/value_temperature"
            app:layout_constraintBottom_toBottomOf="@+id/textViewTemperatureLabel"
            app:layout_constraintEnd_toEndOf="@+id/textViewWindSpeedValue"
            app:layout_constraintStart_toStartOf="@+id/textViewWindSpeedValue"
            app:layout_constraintTop_toTopOf="@+id/textViewTemperatureLabel" />

        <TextView
            android:id="@+id/textViewTimeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="163dp"
            android:text="@string/label_time"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/textViewTemperatureLabel"
            app:layout_constraintStart_toStartOf="@+id/textViewTemperatureLabel"
            app:layout_constraintTop_toBottomOf="@+id/textViewTemperatureLabel" />

        <TextView
            android:id="@+id/textViewTimeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/value_time"
            app:layout_constraintBottom_toBottomOf="@+id/textViewTimeLabel"
            app:layout_constraintEnd_toEndOf="@+id/textViewTemperatureValue"
            app:layout_constraintStart_toStartOf="@+id/textViewTemperatureValue"
            app:layout_constraintTop_toTopOf="@+id/textViewTimeLabel" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>